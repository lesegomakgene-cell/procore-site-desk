# Copy this file to ".env" for LOCAL use, then restart the server.
# (On Render you set these in the dashboard instead, not in this file.)

# Required: your Anthropic API key (kept server-side, never sent to the browser)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Optional settings
MODEL=claude-sonnet-4-6          # cheaper/faster option: claude-haiku-4-5
PORT=3000
SITE_AGENT_NAME=Lesego
SITE_AGENT_EMAIL=                 # optional - shown to users after they book

# Optional: get pinged the instant someone requests a session.
# Paste a Slack or Discord "incoming webhook" URL here. Leave blank to skip.
REQUEST_WEBHOOK_URL=
